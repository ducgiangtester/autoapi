          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "const userManagementUtils = `({\r",
              "    createUser: function (name, email, gender, status) {\r",
              "        const createUserRequest = {\r",
              "            url: pm.environment.get('baseUrl') + '/public/v2/users',\r",
              "            method: 'POST',\r",
              "            header: {\r",
              "                'Content-Type': 'application/json',\r",
              "                // Chỉ cần khai báo Content-Type 1 lần\r",
              "                'Authorization': 'Bearer b99c4db5ceb1f0c7382c003ea65ec17ddef97cde479bef2832ab3b79c39e01eb'\r",
              "            },\r",
              "            body: {\r",
              "                mode: 'raw',\r",
              "                raw: JSON.stringify({\r",
              "                    name: name,\r",
              "                    gender: gender,\r",
              "                    email: email,\r",
              "                    status: status\r",
              "                })\r",
              "            }\r",
              "        };\r",
              "\r",
              "        pm.sendRequest(createUserRequest, function (err, res) {\r",
              "            if (err) {\r",
              "                console.error('Create user failed:', err);\r",
              "            } else {\r",
              "                const responseData = res.json();\r",
              "                console.log('User created successfully:', responseData.name);\r",
              "                // Bạn có thể lưu ID vào environment để dùng cho các request sau\r",
              "                pm.environment.set(\"current_user_id\", responseData.id);\r",
              "            }\r",
              "        });\r",
              "    }\r",
              "})`;\r",
              "pm.globals.set(\"userManagementUtils\", userManagementUtils);"
            ]
          }
        },
